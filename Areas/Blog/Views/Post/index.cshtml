@Html.AntiForgeryToken()

<head>
    <link rel="stylesheet" href="~/lib/froala-editor/css/froala_editor.pkgd.min.css">


</head>
<div class="container-fluid">
    <div class="row">
        <div class="card rounded mb-0 w-100">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb text-dark bg-white mb-0">
                    <li class="px-2 text-dark"><a href="#">Trang chủ <i class="fa-solid fa-chevron-right"></i></a></li>
                    <li class="px-2 text-dark active" aria-current="page">Danh sách bài viết</li>
                </ol>
            </nav>

        </div>
    </div>
</div>
<div class="container-fluid">
    <div class="row">
        <div class="col-12 p-0">
            <div class="card rounded">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 w-100">
                        <div class="d-flex align-items-center w-50">
                            <div class="form-field w-50 ">
                                <input type="search" name="search" class="form-control form-input w-100"
                                    placeholder=" " />
                                <span class="form-label">Tìm kiếm</span>
                            </div>
                            <button class=" box-shadow active px-2 py-1 rounded "><i class="fa-solid fa-magnifying-glass"></i></button>
                        </div>
                        <div class="d-flex align-items-center">
                            <button class="create-post box-shadow button text-white"><i class="fa-solid fa-plus mr-2"></i>Thêm</button>
                            <div>
                                <a class="box-shadow button bg-white text-dark ml-2" asp-action="index" asp-controller="category" asp-area="blog"><i class="fa-solid fa-circle-right mr-2"></i>Chuyên mục</a>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="d-flex align-items-center ">
                            <h4 class="card-title totalUser m-0"></h4>
                            <div class="d-flex align-items-center px-3">
                                <span class="mx-1">Xem</span> <select id="multiple-quantity" class="" multiple="multiple">
                                    <option value=5>5</option>
                                    <option value=10 selected>10</option>
                                    <option value=25>25</option>
                                    <option value=50>50</option>
                                </select> <span class="mx-1">mục</span>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered zero-configuration">
                            <thead>
                                <tr>
                                    <th>Tiêu đề</th>
                                    <th>Ảnh</th>
                                    <th>Ngày đăng</th>
                                    <th>Lượt xem</th>
                                    <th>Trạng thái</th>
                                    <th>Chức năng</th>
                                </tr>
                            </thead>
                            <tbody class="listpost">

                            </tbody>
                        </table>
                    </div>
                </div>
                <div class=" d-flex justify-content-center">
                    <nav aria-label="Page navigation example">
                        <ul class="pagination">
                            <div class="pageNumber d-flex justify-content-center">
                            </div>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="toast"></div>
<script src="~/lib/froala-editor/js/froala_editor.pkgd.min.js"></script>

<body>
    <script type="module" src="~/js/Blog/Post.js"></script>
</body>
