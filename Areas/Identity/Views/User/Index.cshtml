@Html.AntiForgeryToken()
<div class="container-fluid">
    <div class="row">
        <div class="card rounded mb-0 w-100">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb text-dark bg-white mb-0">
                    <li class="px-2 text-dark"><a href="#">Trang chủ <i class="fa-solid fa-chevron-right"></i></a></li>
                    <li class="px-2 text-dark active" aria-current="page">Danh sách người dùng</li>
                </ol>
            </nav>

        </div>
    </div>
</div>
<div class="container-fluid">
    <div class="row">
        <div class="col-12 px-0">
            <div class="card rounded" >
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 w-100">
                        <div class="d-flex align-items-center justify-content-center w-75">
                            <div class="form-field w-50">
                                <input type="search" name="search" class="form-control form-input w-100"
                                    placeholder=" " />
                                <span class="form-label">Tìm kiếm</span>
                            </div>
                            <button class="buttonSearch box-shadow active px-2 py-1 rounded "><i class="fa-solid fa-magnifying-glass"></i></button>
                        </div>
                        <div class="">
                            <a class="box-shadow button bg-white text-dark ml-3" asp-action="index" asp-controller="Role" asp-area="Identity"> <i class="fa-solid fa-circle-right mr-2"></i></i>Quản lý vai trò</a>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="d-flex align-items-center ">
                            <h4 class="card-title totalUser m-0"></h4>
                            <div class="d-flex px-3">
                                <button class="user-all px-3 py-1 mx-2 box-shadow active">Tất cả</button>
                                <button class="user-roles px-3 py-1 mx-2  box-shadow ">Nhân viên</button>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered zero-configuration">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Tên người dùng</th>
                                    <th>Email</th>
                                    <th>Vai trò(Roles)</th>
                                    <th>Chức năng</th>
                                </tr>
                            </thead>
                            <tbody class="list">
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="pagination d-flex justify-content-center"></div>
            </div>
        </div>
    </div>
</div>
<div id="toast"></div>

<script type="module" src="~/js/UserMange.js"></script>
