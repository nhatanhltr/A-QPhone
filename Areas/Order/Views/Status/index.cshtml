@Html.AntiForgeryToken()
<div class="container-fluid">
    <div class="row">
        <div class="card rounded mb-0 w-100">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb text-dark bg-white mb-0">
                    <li class="px-2 text-dark"><a href="#">Trang chủ <i class="fa-solid fa-chevron-right"></i></a></li>
                    <li class="px-2 text-dark active" aria-current="page">Quản lý trạng thái</li>
                </ol>
            </nav>

        </div>
    </div>
</div>
<div class="container-fluid">
    <div class="row">
        <div class="col-12 p-0">
            <div class="card rounded">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 w-100">
                        <div class="d-flex align-items-center w-50">
                            <h3 class="mb-0 animation-text">Quản lý trạng thái</h3>
                        </div>
                        <div class="d-flex align-items-center">
                            <button class="create box-shadow button text-white"><i class="fa-solid fa-plus mr-2"></i>Thêm</button>
                            <div>
                                <a class="box-shadow button bg-white text-dark ml-3" asp-action="index" asp-controller="category" asp-area="blog"><i class="fa-solid fa-circle-right mr-2"></i> Quản lý đơn hàng</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered zero-configuration">
                            <thead> 
                                <tr class="text-center">
                                    <th>STT</th>
                                    <th>Tên trạng thái</th>
                                    <th>Mô tả</th>
                                    <th>Chức năng</th>
                                </tr>
                            </thead>
                            <tbody class="list">

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="toast"></div>

<script type="module" src="~/js/Order/Status.js"></script>