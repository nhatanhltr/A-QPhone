@model dynamic
@{
    Layout = "_LayoutAdmin";
}
@Html.AntiForgeryToken()
<div class="container-fluid">
    <div class="row">
        <div class="card rounded mb-0 w-100">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb text-dark bg-white mb-0">
                    <li class="px-2 text-dark"><a href="#">Trang chủ <i class="fa-solid fa-chevron-right"></i></a></li>
                    <li class="px-2 text-dark active" aria-current="page">Chi tiết hóa đơn</li>
                </ol>
            </nav>

        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-12 px-0">
            <div class="card">
                <div class="card-body">
                    <div class="grid wide">
                        <div class="row">
                            <div class="col col-12">
                                <div class="">
                                    <div class="mb-4 p-2 rounded" style="box-shadow: rgba(0, 0, 0, 0.35) 0px 0px 5px;">
                                        <div class="row">
                                            <div class="col col-12">
                                                <h5 class="text-danger text-center ">Mã hóa đơn: <b class="id-bill">@Model.GUID</b>
                                                </h5>
                                                <hr>
                                                <table class="table table-hover text-center">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col">Tên sản phẩm</th>
                                                            <th scope="col">Hình ảnh</th>
                                                            <th scope="col">Giá</th>
                                                            <th scope="col">Số lượng</th>
                                                        </tr>
                                                    </thead>
                                                    @foreach (var ordetail in @Model.orderDetail)
                                                    {
                                                        <tbody>
                                                            <tr>
                                                                <td class="w-50"><a asp-controller="ProductsClient"
                                                                        asp-action="Details"
                                                                        asp-route-slug="@ordetail.products.Slugp">@ordetail.products.Title</a>
                                                                </td>
                                                                <td><img height="70" src="@ordetail.products.Image" /></td>
                                                                <td><span
                                                                        class="text-danger font-weight-bold">@Functions.VNĐ(ordetail.PriceOrder)đ</span>
                                                                </td>
                                                                <td>@ordetail.Quantity</td>
                                                            </tr>
                                                        </tbody>
                                                    }
                                                </table>
                                            </div>
                                        </div>
                                        <div class="row ">
                                           
                                            <div class="col col-12 mt-2">
                                                <div class="row">
                                                    <div class="col col-12">
                                                        <div class="border p-2 mb-1 rounded w-100">
                                                            <div
                                                                class="text-center p-1 font-weight-bold border-bottom mb-2">
                                                                <i class="fa-solid fa-location-dot mx-2"></i>Địa chỉ
                                                                nhận hàng
                                                            </div>
                                                            <div class="col col-6">
                                                                <h6><span class="font-weight-bold">Họ tên: </span>
                                                                    @Model.FullName</h6>
                                                            </div>
                                                            <div class="col col-6">
                                                                <h6><span class="font-weight-bold">Điện thoại:</span>
                                                                    @Model.PhoneNumber</h6>
                                                            </div>
                                                            <div class="col col-12">
                                                                <h6><span class="font-weight-bold">Địa chỉ:</span>
                                                                    @Model.Address</h6>
                                                            </div>
                                                            <div class="col col-12">
                                                                <h6><span class="font-weight-bold">Ngày đặt hàng:</span>
                                                                    @Model.CreatedDate</h6>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col col-12">
                                                        <div class="border p-2 mb-1 rounded w-100">
                                                            <div
                                                                class="text-center p-1 font-weight-bold border-bottom mb-2">
                                                                <i class="fa-solid fa-truck-moving mx-2"></i>Thông tin
                                                                đơn hàng
                                                            </div>
                                                            <div class="col col-6">
                                                                <h6><span class="font-weight-bold">Tổng tiền:</span>
                                                                    <span
                                                                        class="text-danger font-weight-bold">@Functions.VNĐ(Model.TotalPrice)đ</span>
                                                                </h6>
                                                            </div>
                                                            <div class="col col-6">
                                                                <h6><span class="font-weight-bold">Số lượng:
                                                                    </span>@Model.TotalQuantity sản
                                                                    phẩm
                                                                </h6>
                                                            </div>

                                                            <div class="col col-12">
                                                                <h6><span class="font-weight-bold">Trạng thái đơn hàng: </span><span class="Status-bill text-danger"> @Model.Status.StatusName</span>
                                                                </h6>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col col-12 d-flex justify-content-between">
                                                        <div class="w-75 d-flex align-items-center">
                                                            <b class="mr-2">Trạng thái</b>
                                                            <div class="w-50">
                                                                <select id="multiple" class="select w-100"
                                                                    multiple="multiple">
                                                                </select>
                                                            </div>
                                                            <button class="border button ml-2 p-2 check-status">Phê duyệt</button>
                                                        </div>
                                                        <button class=" Print-bill button bg-info "><i
                                                                class="fa-solid fa-print mr-1"></i>Xem hóa đơn</button>
                                                    </div>
                                                </div>
                                                <div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toast"></div>
<script type="module" src="~/js/Order/OrderDetails.js"></script>
