@Html.AntiForgeryToken()
<div class="container-fluid">
    <div class="row">
        <div class="card rounded mb-0 w-100">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb text-dark bg-white mb-0">
                    <li class="px-2 text-dark"><a href="#">Trang chủ <i class="fa-solid fa-chevron-right"></i></a></li>
                    <li class="px-2 text-dark active" aria-current="page">Đơn hàng</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<div class="container-fluid">
    <div class="row">
        <div class="col-12 p-0">
            <div class="card rounded">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 w-100">
                        <div class="d-flex align-items-center justify-content-center w-75">
                            <div class="form-field w-50">
                                <input type="search" name="search" class="value-search form-control form-input w-100"
                                    placeholder=" " />
                                <span class="form-label">Tìm kiếm theo mã hóa đơn</span>
                            </div>
                            <button class="btn-search box-shadow button rounded "><i
                                    class="fa-solid fa-magnifying-glass"></i></button>
                        </div>
                        <div class="">
                            <a class="box-shadow button bg-white text-dark" href="/admin/status/index"><i
                                    class="fa-solid fa-circle-right mr-2"></i>Danh sách trạng thái</a>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="d-flex align-items-center ">
                            <h4 class="card-title totalUser m-0"></h4>
                            <div class="d-flex align-items-center px-3">
                                <span class="mx-1">Xem</span> <select id="multiple-quantity" class=""
                                    multiple="multiple">
                                    <option value=5>5</option>
                                    <option value=10 selected>10</option>
                                    <option value=25>25</option>
                                    <option value=50>50</option>
                                </select> <span class="mx-1">mục</span>
                            </div>
                            
                            <div class="d-flex px-3">
                                <div class=" d-flex ">
                                    <div class="form-row align-items-center">
                                        <div class="col-auto">
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text">Từ ngày</div>
                                                </div>
                                                <input type="datetime-local" class="form-control fromDate" >
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <div class="input-group mb-2">
                                                <div class="input-group-prepend">
                                                    <div class="input-group-text">Đến</div>
                                                </div>
                                                <input  type="datetime-local" class="form-control toDate" >
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <button type="button" class="filter-bill button mb-2">Lọc</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr>
                    <div class="table-responsive mt-2">
                        <table class="table table-striped table-bordered zero-configuration">
                            <thead>
                                <tr class="text-center">
                                    <th>Mã đơn hàng</th>
                                    <th>Số lượng</th>
                                    <th>Tạm tính</th>
                                    <th>Thuế</th>
                                    <th>Tổng trả</th>
                                    <th>Ngày tạo</th>
                                    <th>Chức năng</th>
                                </tr>
                            </thead>
                            <tbody class="list">

                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="pagination d-flex justify-content-center"></div>
            </div>
        </div>
    </div>
</div>
<div id="toast"></div>

<script type="module" src="~/js/import/listImport.js"></script>
