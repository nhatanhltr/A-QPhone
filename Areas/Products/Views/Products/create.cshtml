                                                <label for="name" class="form-label">Tên sản phẩm (<span
                                                        class="text-danger">*</span>) </label>
                                                <span class="form-message"></span>
                                            </div>
                                        </div>

                                        <div class="col col-12">
                                            <div class="row">
                                                <div class="col col-6">
                                                    <div class="form-group form-field ">
                                                        <input  id="name"
                                                            name="Price" rule="required" placeholder=" "
                                                            class="pnewPrice price form-input form-error form-control ">
                                                        <label for="name" class="form-label">Giá mới (<span
                                                                class="text-danger">*</span>)</label>
                                                        <span class="form-message"></span>
                                                    </div>
                                                </div>
                                                <div class="col col-6">
                                                    <div class="form-group form-field ">
                                                        <input  id="name"
                                                            name="PriceOld" rule="required" placeholder=" "
                                                            class="poldPrice form-input form-error form-control ">
                                                        <label for="name" class="form-label">Giá cũ (<span
                                                                class="text-danger">*</span>)</label>
                                                        <span class="form-message"></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col col-12">
                                            <div class="row">
                                                <div class="col col-6">
