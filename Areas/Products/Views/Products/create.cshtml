                                    <div class="row">
                                        <div class="col col-12">
                                            <select id="multiple" class="select w-100" multiple="multiple">
                                            </select>
                                        </div>

                                        <div class="col col-12">
                                            <div class="form-group form-field ">
                                                <input id="name" name="Title" rule="required" type="text"
